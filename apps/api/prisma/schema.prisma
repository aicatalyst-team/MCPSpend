generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users (identity only — billing lives on Organization) ──

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  passwordHash    String?
  emailVerifiedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Activation drip — timestamps for each step in the welcome sequence so
  // the maintenance scheduler never sends the same email twice. NULL means
  // not sent yet; sent timestamp means delivered (or attempted).
  activationDay2SentAt   DateTime?
  activationDay5SentAt   DateTime?
  reactivationDay14SentAt DateTime?

  memberships     OrganizationMember[]
  invitationsSent Invitation[]         @relation("InvitedBy")
  apiKeysCreated  ApiKey[]             @relation("CreatedBy")
}

// ─── Organizations (billing + ownership boundary) ───────────

model Organization {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  plan                 Plan     @default(FREE)
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  callsThisMonth       Int      @default(0)
  callsLimit           Int      @default(25000)
  billingCycleStart    DateTime @default(now())
  slackWebhookUrl      String?
  lastBudgetAlertAt    DateTime?
  lastBudgetAlertLevel Int?     // last quota-% threshold hit (80, 100)
  // Optional monthly cost cap in USD. When set, the maintenance job alerts
  // on % of THIS budget (in $) rather than % of plan call limit. Lets users
  // protect themselves from runaway spend (e.g. "if my agent makes 200k
  // tool calls accidentally, alert me before $50 spent").
  monthlyBudgetUsd     Float?
  lastSpendAlertAt     DateTime?
  lastSpendAlertLevel  Int?     // last dollar-% threshold hit (50, 80, 100)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  members      OrganizationMember[]
  invitations  Invitation[]
  projects     Project[]
  apiKeys      ApiKey[]
  sessions     Session[]
  toolCalls    ToolCall[]
  dailyStats   DailyStats[]
  auditLogs    AuditLog[]
  webhooks     Webhook[]
  webhookEvents WebhookEvent[]
}

// Compatibility report sent anonymously by the proxy CLI on init/doctor.
// Lets us spot when a client (Windsurf, Cursor, etc.) changes its config schema
// and our auto-discovery silently breaks. No PII — just a fingerprint of the
// top-level config keys we observed plus the CLI version that ran.
model CompatReport {
  id           String   @id @default(cuid())
  cliVersion   String
  platform     String   // win32 / darwin / linux
  clientId     String   // claude-desktop / cursor / windsurf / vscode / claude-code
  status       String   // patched / no-changes / error / dry-run / bootstrapped / not-detected
  configFormat String?  // json / protobuf / binary-unknown / missing
  fingerprint  String?  // sha256(sorted top-level keys), 16 chars
  serverCount  Int?
  wrappedCount Int?
  errorSummary String?
  ipHash       String?  // sha256(ip) — for rate limiting / dedup, not user tracking
  createdAt    DateTime @default(now())

  @@index([clientId, fingerprint, createdAt])
  @@index([clientId, createdAt])
}

// Append-only record of sensitive actions: subscription changes, member kicks,
// API key revocations, settings edits. Shown to Enterprise customers + queried
// by support. Retention: forever for Enterprise, follows ToolCall retention
// for everyone else (cleaned by maintenance.ts).
model AuditLog {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId          String?      // null when the action came from a webhook or system job
  actorEmail      String?      // copied at write time so a user delete doesn't orphan the log
  action          String       // dotted namespace: billing.cancel, billing.upgrade, key.revoke, ...
  target          String?      // ID of the thing acted on (subscription id, key id, ...)
  metadata        Json?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@index([action, createdAt])
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           Role         @default(MEMBER)
  joinedAt       DateTime     @default(now())

  @@unique([organizationId, userId])
  @@index([userId])
}

model Invitation {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email           String
  role            Role         @default(MEMBER)
  tokenHash       String       @unique
  invitedByUserId String
  invitedBy       User         @relation("InvitedBy", fields: [invitedByUserId], references: [id])
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime     @default(now())

  @@index([organizationId, email])
}

// ─── API Keys (per-org, used by the proxy npm package) ──────

model ApiKey {
  id              String        @id @default(cuid())
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId       String?
  project         Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  name            String
  prefix          String
  keyHash         String        @unique
  createdByUserId String
  createdBy       User          @relation("CreatedBy", fields: [createdByUserId], references: [id])
  createdAt       DateTime      @default(now())
  lastUsedAt      DateTime?
  revokedAt       DateTime?

  sessions        Session[]

  @@index([organizationId])
  @@index([projectId])
}

// ─── Projects ───────────────────────────────────────────────

model Project {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  slug            String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  apiKeys     ApiKey[]
  sessions    Session[]
  toolCalls   ToolCall[]
  dailyStats  DailyStats[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

// ─── Sessions (one agent run = one session) ─────────────────

model Session {
  id                String       @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId         String
  project           Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  apiKeyId          String?
  apiKey            ApiKey?      @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  agentName         String?
  model             String?
  startedAt         DateTime     @default(now())
  endedAt           DateTime?
  totalInputTokens  Int          @default(0)
  totalOutputTokens Int          @default(0)
  totalCostUsd      Float        @default(0)
  toolCallCount     Int          @default(0)

  toolCalls         ToolCall[]

  @@index([organizationId, startedAt(sort: Desc)])
  @@index([projectId, startedAt(sort: Desc)])
}

// ─── Tool Calls (core fact table) ───────────────────────────

model ToolCall {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId       String
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sessionId       String?
  session         Session?     @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  serverName      String
  toolName        String
  model           String

  inputTokens     Int
  outputTokens    Int
  costUsd         Float

  latencyMs       Int?
  success         Boolean      @default(true)
  errorCode       String?

  // Optional free-form label that lets agencies / SaaS-on-top of MCP attribute
  // a tool call to their own end-customer. Set via MCPSPEND_CUSTOMER_LABEL env
  // var per wrapped server, OR via the X-MCPSpend-Customer header on
  // /v1/ingest. Anything > 80 chars is truncated. NULL = unattributed.
  customerLabel   String?

  calledAt        DateTime     @default(now())

  @@index([organizationId, calledAt(sort: Desc)])
  @@index([projectId, calledAt(sort: Desc)])
  @@index([sessionId, calledAt(sort: Desc)])
  @@index([organizationId, toolName, calledAt(sort: Desc)])
  @@index([organizationId, customerLabel, calledAt(sort: Desc)])
}

// ─── Daily Stats (pre-aggregated for dashboards) ────────────

model DailyStats {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId       String?
  project         Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  date            DateTime
  serverName      String?
  toolName        String?

  callCount       Int          @default(0)
  inputTokens     Int          @default(0)
  outputTokens    Int          @default(0)
  costUsd         Float        @default(0)
  errorCount      Int          @default(0)
  avgLatencyMs    Float?

  updatedAt       DateTime     @updatedAt

  @@unique([organizationId, projectId, date, serverName, toolName])
  @@index([organizationId, date(sort: Desc)])
  @@index([projectId, date(sort: Desc)])
}

model IngestError {
  id        String   @id @default(cuid())
  payload   Json
  error     String
  retries   Int      @default(0)
  createdAt DateTime @default(now())
}

// ─── Status probes — populate the public /status page ──────────────
//
// Worker ticks every ~5 minutes and POSTs to each known endpoint, storing
// the result here. The /api/public/status endpoint aggregates this into
// 90-day uptime bars + current state. Truly public — no auth on read.
model StatusCheck {
  id        String   @id @default(cuid())
  probe     String   // 'api' | 'mcp-http' | 'dashboard' | 'ingest' | etc.
  status    String   // 'operational' | 'degraded' | 'down'
  latencyMs Int?
  httpCode  Int?
  errorMsg  String?
  createdAt DateTime @default(now())

  @@index([probe, createdAt(sort: Desc)])
  @@index([createdAt])
}

// ─── Webhooks — customer-defined POST endpoints for events ──
//
// Lets enterprises wire MCPSpend into PagerDuty, Datadog, custom systems,
// Zapier, etc. without us having to ship a native integration per vendor.
// Each event delivery is HMAC-SHA256 signed with `secret` so the receiver
// can verify authenticity (X-MCPSpend-Signature header).
model Webhook {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  label           String       // user-facing name, e.g. "PagerDuty critical"
  targetUrl       String       // https://… — POSTed on every matched event
  secret          String       // signing secret (random 32-byte hex, shown once)
  events          String[]     // event types subscribed to: budget.alert, spend.alert, key.revoke, etc.
  isActive        Boolean      @default(true)
  // Stats — bumped from the dispatcher so the dashboard can show
  // last-delivery status without joining WebhookEvent on every render.
  lastDeliveryAt  DateTime?
  lastDeliveryStatus Int?      // HTTP code from the most recent attempt
  consecutiveFailures Int     @default(0)
  createdByUserId String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  deliveries      WebhookEvent[]

  @@index([organizationId])
}

// Audit-style log of every delivery attempt. Used by the dashboard to show
// "last 100 events" + by the auto-disable logic that pauses a webhook after
// too many consecutive failures.
model WebhookEvent {
  id              String       @id @default(cuid())
  webhookId       String
  webhook         Webhook      @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  eventType       String       // budget.alert, spend.alert, anomaly.detected, etc.
  payload         Json
  httpStatus      Int?         // null = network error before we got a response
  responseBody    String?      // first 500 chars of response, for debugging
  attempts        Int          @default(1)
  succeeded       Boolean
  createdAt       DateTime     @default(now())

  @@index([webhookId, createdAt(sort: Desc)])
  @@index([organizationId, createdAt(sort: Desc)])
}

enum Plan {
  FREE
  PRO
  TEAM
  ENTERPRISE
}
