generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ──────────────────────────────────────────

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  passwordHash     String?
  plan             Plan     @default(FREE)
  stripeCustomerId String?  @unique
  // API key used by the proxy npm package (format: sk-mcs-...)
  apiKey           String   @unique @default(cuid())
  // Monthly quota tracking (reset each billing cycle)
  callsThisMonth   Int      @default(0)
  callsLimit       Int      @default(50000)   // FREE tier: 50K/month
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  projects         Project[]
  sessions         Session[]
  dailyStats       DailyStats[]
}

// ─── Projects (logical grouping of MCP servers) ────────────

model Project {
  id          String   @id @default(cuid())
  name        String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions    Session[]
  dailyStats  DailyStats[]

  @@index([userId])
}

// ─── Sessions (one agent run = one session) ────────────────

model Session {
  id                String    @id @default(cuid())
  projectId         String
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentName         String?
  model             String?
  startedAt         DateTime  @default(now())
  endedAt           DateTime?
  totalInputTokens  Int       @default(0)
  totalOutputTokens Int       @default(0)
  totalCostUsd      Float     @default(0)
  toolCallCount     Int       @default(0)

  toolCalls         ToolCall[]

  @@index([projectId, startedAt(sort: Desc)])
  @@index([userId, startedAt(sort: Desc)])
}

// ─── Tool Calls (core fact table — partitioned in Postgres) ─
// NOTE: After first migration, run:
//   ALTER TABLE "ToolCall" PARTITION BY RANGE ("calledAt");
//   CREATE TABLE tool_call_2026_05 PARTITION OF "ToolCall"
//     FOR VALUES FROM ('2026-05-01') TO ('2026-06-01');
// We do this manually via migration after initial deploy.

model ToolCall {
  id            String   @id @default(cuid())
  userId        String
  projectId     String
  sessionId     String?
  session       Session? @relation(fields: [sessionId], references: [id])

  serverName    String           // e.g. "filesystem", "github"
  toolName      String           // e.g. "read_file", "search_code"
  model         String           // e.g. "claude-sonnet-4-6"

  inputTokens   Int
  outputTokens  Int
  costUsd       Float            // pre-calculated at ingest time

  latencyMs     Int?
  success       Boolean  @default(true)
  errorCode     String?

  calledAt      DateTime @default(now())

  @@index([userId, calledAt(sort: Desc)])
  @@index([projectId, calledAt(sort: Desc)])
  @@index([sessionId, calledAt(sort: Desc)])
  @@index([userId, toolName, calledAt(sort: Desc)])
}

// ─── Daily Stats (pre-aggregated — DO NOT query ToolCall for dashboards) ─

model DailyStats {
  id              String  @id @default(cuid())
  userId          String
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  date            DateTime  // midnight UTC of the day
  serverName      String?   // null = total for that day
  toolName        String?   // null = total for server or day

  callCount       Int      @default(0)
  inputTokens     Int      @default(0)
  outputTokens    Int      @default(0)
  costUsd         Float    @default(0)
  errorCount      Int      @default(0)
  avgLatencyMs    Float?

  updatedAt       DateTime @updatedAt

  // Unique constraint: one row per (user, project, date, server, tool)
  @@unique([userId, projectId, date, serverName, toolName])
  @@index([userId, date(sort: Desc)])
  @@index([projectId, date(sort: Desc)])
}

// ─── Ingest Queue overflow tracking ────────────────────────

model IngestError {
  id        String   @id @default(cuid())
  payload   Json
  error     String
  retries   Int      @default(0)
  createdAt DateTime @default(now())
}

enum Plan {
  FREE        // 50K calls/month
  PRO         // 1M calls/month  — $29/mo
  TEAM        // 10M calls/month — $99/mo
  ENTERPRISE  // unlimited       — $499+/mo
}
